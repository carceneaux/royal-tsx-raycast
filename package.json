{
  "$schema": "https://www.raycast.com/schemas/extension.json",
  "name": "royal-tsx",
  "title": "Royal TSX",
  "description": "Search and connect to Royal TSX connections",
  "icon": "extension-icon.png",
  "author": "chris",
  "categories": ["Developer Tools"],
  "license": "MIT",
  "commands": [
    {
      "name": "connect",
      "title": "Connect",
      "description": "Search and connect to Royal TSX connections",
      "mode": "view"
    }
  ],
  "dependencies": {
    "@raycast/api": "^1.93.2",
    "@raycast/utils": "^1.19.1"
  },
  "devDependencies": {
    "@raycast/eslint-config": "^1.0.11",
    "@types/node": "^22.0.0",
    "@types/react": "^19.0.0",
    "eslint": "^8.57.0",
    "typescript": "^5.7.0"
  },
  "scripts": {
    "build": "ray build",
    "dev": "ray develop",
    "fix-lint": "ray lint --fix",
    "lint": "ray lint",
    "publish": "npx @raycast/api@latest publish"
  }
}
